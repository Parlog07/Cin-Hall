# Admin credentials
# The admin account must already exist in the database with is_admin = 1
@adminEmail = abdo@example.com
@adminPassword = abdo123


@adminToken = eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9.eyJpc3MiOiJodHRwOi8vMTI3LjAuMC4xOjgwMDAvYXBpL2xvZ2luIiwiaWF0IjoxNzczODM1MjMwLCJleHAiOjE3NzM4Mzg4MzAsIm5iZiI6MTc3MzgzNTIzMCwianRpIjoiTW5wVGJab0RQSHFvWmJlciIsInN1YiI6IjEiLCJwcnYiOiIyM2JkNWM4OTQ5ZjYwMGFkYjM5ZTcwMWM0MDA4NzJkYjdhNTk3NmY3In0.WEckXM8q1mKJCglS4oR_u9hMjw84IaFA3XD5Xe4xh3w
# Existing related records required by session creation
@filmId = 1
@roomId = 1

###
# Health check
GET {{baseUrl}}/

###
# Register a normal user
POST {{baseUrl}}/register
Content-Type: application/json

{
  "name": "{{userName}}",
  "email": "{{userEmail}}",
  "password": "{{userPassword}}",
  "password_confirmation": "{{userPassword}}"
}

###
# Login as normal user
# Saves {{userToken}}
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "{{userEmail}}",
  "password": "{{userPassword}}"
}


###
# Get current normal user
GET {{baseUrl}}/user
Authorization: Bearer {{userToken}}

###
# Update current normal user
PUT {{baseUrl}}/user
Authorization: Bearer {{userToken}}
Content-Type: application/json

{
  "name": "Updated Rest Client User"
}

###
# Non-admin should be forbidden from listing sessions
GET {{baseUrl}}/sessions
Authorization: Bearer {{userToken}}

###
# Login as admin
# Saves {{adminToken}}
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}


###
# Get current admin user
GET {{baseUrl}}/user
Authorization: Bearer {{adminToken}}

###
# List sessions as admin
GET {{baseUrl}}/sessions
Authorization: Bearer {{adminToken}}

###
# Filter sessions by type
GET {{baseUrl}}/sessions/filter?type=VIP
Authorization: Bearer {{adminToken}}

###
# Create session as admin
# Saves {{sessionId}}
POST {{baseUrl}}/sessions
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "language": "English",
  "price": 120,
  "start_time": "2026-03-20 20:00:00",
  "type": "VIP",
  "film_id": {{filmId}},
  "room_id": {{roomId}}
}



###
# Show created session
GET {{baseUrl}}/sessions
Authorization: Bearer {{adminToken}}

###
# Update created session
PUT {{baseUrl}}/sessions
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "language": "French",
  "price": 150,
  "type": "normal"
}

###
# Delete created session
DELETE {{baseUrl}}/sessions/1
Authorization: Bearer {{adminToken}}

###
# Logout admin
POST {{baseUrl}}/logout
Authorization: Bearer {{adminToken}}

###
# Logout normal user
POST {{baseUrl}}/logout
Authorization: Bearer {{userToken}}
